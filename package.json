{
  "name": "ticketing-system-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "Frontend",
    "Backend"
  ],
  "scripts": {
    "start": "concurrently \"npm run start:dev --workspace=Backend\" \"npm run dev --workspace=Frontend\"",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
